list2env(prt, .GlobalEnv)
troll<-neonUtilities::loadByProduct(dpID="DP1.20054.001", site=siteName, startdate=startDate,
enddate=endDate, package="expanded", include.provisional=T, check.size = F)
list2env(troll, .GlobalEnv)
#' Separates dataframes by locations
prtS1<-TSW_5min[(TSW_5min$horizontalPosition==111),]
prtS2<-TSW_5min[(TSW_5min$horizontalPosition==112),]
trollS1<-TOSW_5_min[(TOSW_5_min$horizontalPosition==131),]
trollS2<-TOSW_5_min[(TOSW_5_min$horizontalPosition==132),]
#' Creates clean dataframes
prtS1_clean<-prtS1[(prtS1$finalQF==0),]
prtS2_clean<-prtS2[(prtS2$finalQF==0),]
trollS1_clean<-trollS1[(trollS1$sWatTempFinalQF==0),]
trollS2_clean<-trollS2[(trollS2$sWatTempFinalQF==0),]
#' Load logged sonde data
sondeS1<-read.csv(file="HOPB_S1_temp.csv")
sondeS1$startDateTime<-as.POSIXct(sondeS1$startDateTime, tz="GMT", format="%Y-%m-%d %H:%M")
sondeS1$startDateTime<-lubridate::round_date(sondeS1$startDateTime,unit="5 minute")
sondeS1<-plyr::ddply(sondeS1,c("startDateTime"),summarise,sondeTemp=mean(sondeTemp))
library(plyr)
#' Separates dataframes by locations
prtS1<-TSW_5min[(TSW_5min$horizontalPosition==111),]
prtS2<-TSW_5min[(TSW_5min$horizontalPosition==112),]
trollS1<-TOSW_5_min[(TOSW_5_min$horizontalPosition==131),]
trollS2<-TOSW_5_min[(TOSW_5_min$horizontalPosition==132),]
#' Creates clean dataframes
prtS1_clean<-prtS1[(prtS1$finalQF==0),]
prtS2_clean<-prtS2[(prtS2$finalQF==0),]
trollS1_clean<-trollS1[(trollS1$sWatTempFinalQF==0),]
trollS2_clean<-trollS2[(trollS2$sWatTempFinalQF==0),]
#' Load logged sonde data
sondeS1<-read.csv(file="HOPB_S1_temp.csv")
sondeS1$startDateTime<-as.POSIXct(sondeS1$startDateTime, tz="GMT", format="%Y-%m-%d %H:%M")
sondeS1$startDateTime<-lubridate::round_date(sondeS1$startDateTime,unit="5 minute")
sondeS1<-plyr::ddply(sondeS1,c("startDateTime"),summarise,sondeTemp=mean(sondeTemp))
sondeS2<-read.csv(file="HOPB_S2_temp.csv")
sondeS2$startDateTime<-as.POSIXct(sondeS2$startDateTime, tz="GMT", format="%Y-%m-%d %H:%M")
sondeS2$startDateTime<-lubridate::round_date(sondeS2$startDateTime,unit="5 minute")
sondeS2<-plyr::ddply(sondeS2,c("startDateTime"),summarise,sondeTemp=mean(sondeTemp))
#' Create dataframes of paired data
dataS1<-merge(prtS1_clean,trollS1_clean,by.x="startDateTime",by.y="startDateTime",all.x=F,all.y=F)
dataS1<-dataS1[,c("startDateTime", "horizontalPosition.x","surfWaterTempMean","surfacewaterTempMean")]
colnames(dataS1) <- c("startDateTime","location","prtTemp", "trollTemp")
dataS1<-merge(dataS1,sondeS1,by.x="startDateTime",by.y="startDateTime",all.x=F,all.y=F)
dataS2<-merge(prtS2_clean,trollS2_clean,by.x="startDateTime",by.y="startDateTime",all.x=F,all.y=F)
dataS2<-dataS2[,c("startDateTime", "horizontalPosition.x","surfWaterTempMean","surfacewaterTempMean")]
colnames(dataS2) <- c("startDateTime", "location","prtTemp", "trollTemp")
dataS2<-merge(dataS2,sondeS2,by.x="startDateTime",by.y="startDateTime",all.x=F,all.y=F)
dataAll<-rbind(dataS1,dataS2)
dataAllNonPRT<-dataAll[(!is.na(dataAll$nonprtDiff)),]
dataLessUncert<-dataAllNonPRT[(abs(dataAllNonPRT$nonprtDiff<=0.1)),]
View(dataAll)
percentUncert=nrow(dataLessUncert)/nrow(dataAllNonPRT)
dataAll$trollDiff<-dataAll$prtTemp-dataAll$trollTemp
dataAll$sondeDiff<-dataAll$prtTemp-dataAll$sondeTemp
dataAll$nonprtDiff<-dataAll$sondeTemp-dataAll$trollTemp
dataAllNonPRT<-dataAll[(!is.na(dataAll$nonprtDiff)),]
dataLessUncert<-dataAllNonPRT[(abs(dataAllNonPRT$nonprtDiff<=0.1)),]
percentUncert=nrow(dataLessUncert)/nrow(dataAllNonPRT)
dataAllNonPRT<-dataAll[(!is.na(dataAll$nonprtDiff)),]
dataLessUncert<-dataAllNonPRT[(abs(dataAllNonPRT$nonprtDiff<=0.2)),]
percentUncert=nrow(dataLessUncert)/nrow(dataAllNonPRT)
dataAllNonPRT<-dataAll[(!is.na(dataAll$nonprtDiff)),]
dataLessUncert<-dataAllNonPRT[(abs(dataAllNonPRT$nonprtDiff<=0.25)),]
percentUncert=nrow(dataLessUncert)/nrow(dataAllNonPRT)
dataAllNonPRT<-dataAll[(!is.na(dataAll$nonprtDiff)),]
dataLessUncert<-dataAllNonPRT[(abs(dataAllNonPRT$nonprtDiff<=0.3)),]
percentUncert=nrow(dataLessUncert)/nrow(dataAllNonPRT)
siteID <- "CARI"
# Pulls surface water chemistry data from NEON data portal and loads tables into R environment
inputData <- neonUtilities::loadByProduct(
dpID = "DP1.20093.001",
site = siteID,
startdate = "2023-10",
enddate = "2024-09",
package = "expanded",
include.provisional = T,
check.size = F
)
absorbanceData <- inputData[[grep("externalLabAbsorbanceScan", names(inputData))]]
concentrationData <- inputData[[grep("externalLabDataByAnalyte", names(inputData))]]
