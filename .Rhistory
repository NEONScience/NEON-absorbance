FALSE)
csd<- neonUtilities::loadByProduct(
dpID = "DP4.00130.001",
site = siteID,
startdate = "2023-10",
enddate = "2024-09",
package = "expanded",
include.provisional = T,
check.size = F
)
list2env(csd,.GlobalEnv)
View(csd_15_min)
outputSuva254$collectDate<-lubridate::round_date(outputSuva254$collectDate,unit="15 minutes")
csd_15_min<-csd_15_min[,c("startDateTime","dischargeContinuous")]
outputSuva254$collectDate<-lubridate::round_date(outputSuva254$collectDate,unit="15 minutes")
outputSuva254<-merge(outputSuva254,csd_15_min,by.x="collectDate",by.y="startDateTime",all.x=T,all.y=F)
View(outputSuva254)
