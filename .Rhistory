siteID <- c("all")
# Pulls surface water chemistry data from NEON data portal and loads tables into R environment
inputData <- neonUtilities::loadByProduct(dpID = "DP1.20093.001",site = siteID,startdate = "2023-10",enddate = "2026-03",package = "expanded",include.provisional = T,check.size = F,
token="eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzI1NiJ9..YmAq_qJdZFiHLZRNrpA0muT3w70pwwukWPOUPJ73_bogfKps-1JSuxnVyp2wTYQuvDAFga7ltDPJj_SUQ9a1Iw")
# Assigns data table names regardless of swc or gwc prefix
absorbanceData <- inputData[[grep("externalLabAbsorbanceScan", names(inputData))]]
concentrationData <- inputData[[grep("externalLabDataByAnalyte", names(inputData))]]
dataDOC<-concentrationData[(concentrationData$analyte=="DOC"),]
dataFe<-concentrationData[(concentrationData$analyte=="Fe"),]
dataAbs<-concentrationData[(concentrationData$analyte=="UV Absorbance (254 nm)"),]
# Creates table of min and max values (1.5xIQR) for filtering outliers
rangeDOC<-dataDOC |> dplyr::group_by(siteID) |>
dplyr::summarize(
q1=quantile(analyteConcentration, probs=c(.25), na.rm = T),
q3=quantile(analyteConcentration, probs=c(.75), na.rm = T),
avg=mean(analyteConcentration,na.rm=T),
stdev=sd(analyteConcentration,na.rm=T))
rangeDOC$minDOCiqr=rangeDOC$q1-(1.5*(rangeDOC$q3-rangeDOC$q1))
rangeDOC$maxDOCiqr=rangeDOC$q3+(1.5*(rangeDOC$q3-rangeDOC$q1))
rangeDOC$minDOCsd=rangeDOC$avg-(2*(rangeDOC$stdev))
rangeDOC$maxDOCsd=rangeDOC$avg+(2*(rangeDOC$stdev))
rangeDOC<-rangeDOC[,c("siteID","minDOCiqr","maxDOCiqr","minDOCsd","maxDOCsd")]
rangeFe<-dataFe |> dplyr::group_by(siteID) |>
dplyr::summarize(
q1=quantile(analyteConcentration, probs=c(.25), na.rm = T),
q3=quantile(analyteConcentration, probs=c(.75), na.rm = T),
avg=mean(analyteConcentration,na.rm=T),
stdev=sd(analyteConcentration,na.rm=T))
rangeFe$minFeiqr=rangeFe$q1-(1.5*(rangeFe$q3-rangeFe$q1))
rangeFe$maxFeiqr=rangeFe$q3+(1.5*(rangeFe$q3-rangeFe$q1))
rangeFe$minFesd=rangeFe$avg-(2*(rangeFe$stdev))
rangeFe$maxFesd=rangeFe$avg+(2*(rangeFe$stdev))
rangeFe<-rangeFe[,c("siteID","minFeiqr","maxFeiqr","minFesd","maxFesd")]
rangeAbs<-dataAbs |> dplyr::group_by(siteID) |>
dplyr::summarize(
q1=quantile(analyteConcentration, probs=c(.25), na.rm = T),
q3=quantile(analyteConcentration, probs=c(.75), na.rm = T),
avg=mean(analyteConcentration,na.rm=T),
stdev=sd(analyteConcentration,na.rm=T))
rangeAbs$minAbsiqr=rangeAbs$q1-(1.5*(rangeAbs$q3-rangeAbs$q1))
rangeAbs$maxAbsiqr=rangeAbs$q3+(1.5*(rangeAbs$q3-rangeAbs$q1))
rangeAbs$minAbssd=rangeAbs$avg-(2*(rangeAbs$stdev))
rangeAbs$maxAbssd=rangeAbs$avg+(2*(rangeAbs$stdev))
rangeAbs<-rangeAbs[,c("siteID","minAbsiqr","maxAbsiqr","minAbssd","maxAbssd")]
# Filters outliers
for(i in 1:nrow(rangeDOC)){
for(j in 1:nrow(dataDOC)){
if(rangeDOC[i,which(colnames(rangeDOC)=="siteID")]==dataDOC[j,which(colnames(dataDOC)=="siteID")]){
if(!is.na(dataDOC[j,which(colnames(dataDOC)=="analyteConcentration")]))(
{if(dataDOC[j,which(colnames(dataDOC)=="analyteConcentration")]<rangeDOC[i,2]|
dataDOC[j,which(colnames(dataDOC)=="analyteConcentration")]>rangeDOC[i,3]){
dataDOC[j,which(colnames(dataDOC)=="analyteConcentration")]=NA}})
}
}
}
for(i in 1:nrow(rangeFe)){
for(j in 1:nrow(dataFe)){
if(rangeFe[i,which(colnames(rangeFe)=="siteID")]==dataFe[j,which(colnames(dataFe)=="siteID")]){
if(!is.na(dataFe[j,which(colnames(dataFe)=="analyteConcentration")]))(
{if(dataFe[j,which(colnames(dataFe)=="analyteConcentration")]<rangeFe[i,2]|
dataFe[j,which(colnames(dataFe)=="analyteConcentration")]>rangeFe[i,3]){
dataFe[j,which(colnames(dataFe)=="analyteConcentration")]=NA}})
}
}
}
for(i in 1:nrow(rangeAbs)){
for(j in 1:nrow(dataAbs)){
if(rangeAbs[i,which(colnames(rangeAbs)=="siteID")]==dataAbs[j,which(colnames(dataAbs)=="siteID")]){
if(!is.na(dataAbs[j,which(colnames(dataAbs)=="analyteConcentration")]))(
{if(dataAbs[j,which(colnames(dataAbs)=="analyteConcentration")]<rangeAbs[i,2]|
dataAbs[j,which(colnames(dataAbs)=="analyteConcentration")]>rangeAbs[i,3]){
dataAbs[j,which(colnames(dataAbs)=="analyteConcentration")]=NA}})
}
}
}
# Recombines concentration data for use in absNEON package
concentrationData<-rbind(dataDOC,dataFe,dataAbs)
outputSuva254 <- absNEON::calcSuva254(absorbanceData, concentrationData, correctFe = TRUE)
outputSuva350 <- absNEON::calcSuva350(absorbanceData, concentrationData, correctFe = TRUE)
outputE2E3<-absNEON::calcE2E3(absorbanceData, concentrationData, correctFe = TRUE)
outputSR <- absNEON::calcSR(absorbanceData, concentrationData, correctFe = TRUE)
# Formats into single output table
dataDOC<-na.omit(dataDOC[,c("sampleID","domainID","siteID","analyteConcentration")])
colnames(dataDOC)<-c("sampleID","domainID","siteID","DOC")
dataFe<-na.omit(dataFe[,c("sampleID","analyteConcentration")])
colnames(dataFe)<-c("sampleID","Fe")
dataAbs<-na.omit(dataAbs[,c("sampleID","analyteConcentration")])
colnames(dataAbs)<-c("sampleID","Abs")
outputSuva254<-outputSuva254[,c("sampleID","suva254","suva254Corrected")]
outputSuva350<-outputSuva350[,c("sampleID","suva350","suva350Corrected")]
outputE2E3<-outputE2E3[,c("sampleID","E2E3","E2E3Corrected")]
outputSR<-outputSR[,c("sampleID","SR","SRCorrected")]
outputTable<-merge(dataDOC,dataAbs,by.x="sampleID",by.y="sampleID",all.x=FALSE,all.y=FALSE)  # Only samples with valid DOC and Abs included in final data table
