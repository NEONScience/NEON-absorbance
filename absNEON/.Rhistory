combinedData<-merge(absorbanceAveraged, DOC,by.x="sampleID",by.y="sampleID")
# Adds Fe concentrations if input condition is true
if(correctFe == TRUE){
Fe<-concentrationData[(concentrationData$analyte=="Fe"),]
