siteID<-"COMO"
#' Pulls surface water chemistry data from NEON data portal and loads tables into R environment
inputData<-neonUtilities::loadByProduct(dpID="DP1.20093.001", site=siteID, startdate="2023-10",enddate="2025-09",
package="expanded", include.provisional=T, check.size = F)
#' Assigns data table names regardless of swc or gwc prefix
absorbanceData<-inputData[[grep("externalLabAbsorbanceScan",names(inputData))]]
concentrationData<-inputData[[grep("externalLabDataByAnalyte",names(inputData))]]
calcE4E5<-function(
absorbanceData,
concentrationData,
correctFe=FALSE){
if(nrow(absorbanceData) < 1){
print("Error: No absorbance data")
return(NULL)
}
#' Averages replicate absorbance scans
absorbanceData$sampleID.wavelength<-paste(absorbanceData$sampleID, absorbanceData$wavelength, sep=".")
absorbanceData<-plyr::ddply(absorbanceData,c("sampleID.wavelength"),summarise,sampleID=unique(sampleID),domainID=unique(domainID),siteID=unique(siteID),
collectDate=unique(collectDate),wavelength=unique(wavelength),absorbance=mean(decadicAbsorbance))
absorbanceData$sampleID.wavelength<-NULL
#' No concentration required if Fe correction not performed
combinedData<-absorbanceData
#' Adds Fe concentrations if input condition is true
if(correctFe == TRUE){
Fe<-concentrationData[(concentrationData$analyte=="Fe"),]
if(nrow(Fe) < 1){
print("Error: No concentration data")
return(NULL)
}
Fe<-Fe[,c("sampleID","analyteConcentration")]
colnames(Fe)<-c("sampleID","Fe")
combinedData<-merge(absorbanceData, Fe,by.x="sampleID",by.y="sampleID")
combinedData$absorbanceFe<-combinedData$Fe*((-0.00000044*(combinedData$wavelength^2))-(0.00007755*combinedData$wavelength)+0.11337671)
combinedData$absorbanceCorrected<-combinedData$absorbance-combinedData$absorbanceFe
}
#' Performs calculation without any corrections
abs465<-combinedData[(combinedData$wavelength=="464"|combinedData$wavelength=="466"),]
abs465<-plyr::ddply(abs465,c("sampleID"),summarise,abs465=mean(absorbance)) #Estimates 465 from average of 464 and 466
abs665<-combinedData[(combinedData$wavelength=="664"|combinedData$wavelength=="666"),]
abs665<-plyr::ddply(abs665,c("sampleID"),summarise,abs665=mean(absorbance)) #Estimates 665 from average of 664 and 666
E4E5<-merge(abs465,abs665,by.x="sampleID",by.y="sampleID",all.x=T,all.y=T)
E4E5$E4E5<-E4E5$abs465/E4E5$abs665
#' Performs calculation with Fe correction
if(correctFe == TRUE){
abs465Corrected<-combinedData[(combinedData$wavelength=="464"|combinedData$wavelength=="466"),]
abs465Corrected<-plyr::ddply(abs465Corrected,c("sampleID"),summarise,abs465Corrected=mean(absorbance)) #Estimates 465 from average of 464 and 466
abs665Corrected<-combinedData[(combinedData$wavelength=="664"|combinedData$wavelength=="666"),]
abs665Corrected<-plyr::ddply(abs665Corrected,c("sampleID"),summarise,abs665Corrected=mean(absorbance)) #Estimates 665 from average of 664 and 666
E4E5Corrected<-merge(abs465Corrected,abs665Corrected,by.x="sampleID",by.y="sampleID",all.x=T,all.y=T)
E4E5Corrected$E4E5Corrected<-E4E5Corrected$abs465Corrected/E4E5Corrected$abs665Corrected
}
#' Formats output table
outputTable<-unique(absorbanceData[,c("domainID","siteID","sampleID","collectDate")])
outputTable<-merge(outputTable,E2E3,by.x="sampleID",by.y="sampleID",all.x=T,all.y=F)
outputTable<-outputTable[,c("domainID","siteID","sampleID","collectDate","E2E3")]
if(correctFe == TRUE){
outputTable<-merge(outputTable,E4E5Corrected,by.x="sampleID",by.y="sampleID",all.x=T,all.y=F)
outputTable<-outputTable[,c("domainID","siteID","sampleID","collectDate","E4E5","E4E5Corrected")]
}
return(outputTable)
}
outputE4E5<-calcE4E5(absorbanceData,concentrationData,correctFe=TRUE)
library(plyr)
outputE4E5<-calcE4E5(absorbanceData,concentrationData,correctFe=TRUE)
absorbanceData$sampleID.wavelength<-paste(absorbanceData$sampleID, absorbanceData$wavelength, sep=".")
absorbanceData<-plyr::ddply(absorbanceData,c("sampleID.wavelength"),summarise,sampleID=unique(sampleID),domainID=unique(domainID),siteID=unique(siteID),
collectDate=unique(collectDate),wavelength=unique(wavelength),absorbance=mean(decadicAbsorbance))
absorbanceData$sampleID.wavelength<-NULL
Fe<-concentrationData[(concentrationData$analyte=="Fe"),]
if(nrow(Fe) < 1){
print("Error: No concentration data")
return(NULL)
}
Fe<-Fe[,c("sampleID","analyteConcentration")]
colnames(Fe)<-c("sampleID","Fe")
combinedData<-merge(absorbanceData, Fe,by.x="sampleID",by.y="sampleID")
combinedData$absorbanceFe<-combinedData$Fe*((-0.00000044*(combinedData$wavelength^2))-(0.00007755*combinedData$wavelength)+0.11337671)
combinedData$absorbanceCorrected<-combinedData$absorbance-combinedData$absorbanceFe
View(combinedData)
devtools::document()
