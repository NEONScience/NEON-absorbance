wideFormat <- longFormat
absorbanceData,
wideFormat <- reshape(
longFormat,
idvar = "sampleID",        # Variables that identify a unique row in wide format
timevar = "wavelength",      # Variable that defines the multiple measurements per subject
v.names = "absorbance", # Variables to be converted to multiple columns
direction = "wide"     # Specify the direction of reshaping
)
View(longFormat)
View(wideFormat)
wideFormat <- reshape(
longFormat,
idvar = c("domainID","sampleID"),        # Variables that identify a unique row in wide format
timevar = "wavelength",      # Variable that defines the multiple measurements per subject
v.names = "absorbance", # Variables to be converted to multiple columns
direction = "wide"     # Specify the direction of reshaping
)
outputTable<-unique(absorbanceData[,c("domainID","siteID","sampleID","collectDate")])
outputTable<-merge(outputTable,wideFormat,by.x="sampleID",by.y="sampleID",all.x=T,all.y=F)
View(outputTable)
outputTable<-outputTable[, c(2,3,1,4:195)]
View(outputTable)
formatWide<-function(
absorbanceData){
if(nrow(absorbanceData) < 1){
print("Error: No absorbance data")
return(NULL)
}
#' Averages replicate absorbance scans
absorbanceData$sampleID.wavelength<-paste(absorbanceData$sampleID, absorbanceData$wavelength, sep=".")
absorbanceData<-plyr::ddply(absorbanceData,c("sampleID.wavelength"),summarise,sampleID=unique(sampleID),domainID=unique(domainID),siteID=unique(siteID),
collectDate=unique(collectDate),wavelength=unique(wavelength),absorbance=mean(decadicAbsorbance))
absorbanceData$sampleID.wavelength<-NULL
#' Converts to wide format
wideFormat <- base::reshape(
longFormat,
idvar = c("sampleID"),
timevar = "wavelength",
v.names = "absorbance",
direction = "wide"
)
#' Formats output table
outputTable<-unique(absorbanceData[,c("domainID","siteID","sampleID","collectDate")])
outputTable<-merge(outputTable,wideFormat,by.x="sampleID",by.y="sampleID",all.x=T,all.y=F)
outputTable<-outputTable[, c(2,3,1,4:195)]
return(outputTable)
}
absorbanceData<-inputData[[grep("externalLabAbsorbanceScan",names(inputData))]]
concentrationData<-inputData[[grep("externalLabDataByAnalyte",names(inputData))]]
outputWide<-formatWide(absorbanceData)
